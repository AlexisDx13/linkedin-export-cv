# EditorConfig — base rules for all projects
# https://editorconfig.org
root = true

# Base: applies to all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Makefiles: require actual tabs, not spaces
[{Makefile,makefile,*.mk}]
indent_style = tab

# Data/config: 2-space indentation by convention
[*.{yml,yaml,json,jsonc}]
indent_size = 2

# Windows batch files: require CRLF
[*.{bat,cmd}]
end_of_line = crlf
